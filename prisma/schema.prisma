generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String
  phone       String
  city        String?
  course      String?
  university  String?
  message     String?
  sourcePage  String?
  referralCode String?
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  image       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model University {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  location    String
  logo        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Page {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   Json
  updatedAt DateTime @updatedAt
}

model Settings {
  id        String   @id @default("default")
  phone     String
  whatsapp  String?
  email     String
  address   String
  facebook  String?
  instagram String?
  twitter   String?
  linkedin  String?
  metaPixelId String?
}

model Partner {
  id                String   @id @default(cuid())
  fullName          String
  email             String   @unique
  mobile            String
  whatsapp          String
  passwordHash      String
  affiliateCode     String   @unique  // e.g. "CSEC-AB12XY"
  affiliateLink     String   @unique  // full URL: csecgwl.com/apply?ref=CSEC-AB12XY
  status            String   @default("active")  // active | suspended
  country           String?
  city              String?
  organization      String?
  totalEarnings     Float    @default(0)
  pendingEarnings   Float    @default(0)
  paidEarnings      Float    @default(0)
  createdAt         DateTime @default(now())
  students          Student[]
  earnings          Earning[]
}

model Student {
  id                String   @id @default(cuid())
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id])
  studentName       String
  fatherName        String
  motherName        String
  address           String
  city              String
  state             String
  pincode           String
  mobile            String
  email             String
  academicQual      String   // e.g. "12th Pass, 75%"
  interestedCourse  String   // B.Tech / MBA / MBBS / BBA / Study Abroad etc.
  preferredUniv     String?
  query             String?
  documents         Json     // Array of {fileName, fileUrl, fileType}
  status            String   @default("new") // new | in_review | admitted | rejected
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Earning {
  id                String   @id @default(cuid())
  partnerId         String
  partner           Partner  @relation(fields: [partnerId], references: [id])
  studentId         String
  amount            Float
  type              String   // "commission" | "bonus"
  status            String   @default("pending") // pending | paid
  note              String?
  createdAt         DateTime @default(now())
}

